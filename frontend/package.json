{
  "name": "neogym-frontend",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "vite dev --mode development",
    "build": "vite build --mode production && tsc --noEmit",
    "preview": "vite preview",
    "start": "node .output/server/index.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "codegen:graphql": "graphql-codegen --config codegen.ts",
    "codegen:graphql-schema": "rover graph introspect --skip-update-check -H \"X-Hasura-Role: user\" -H \"X-Hasura-Admin-Secret: nhost-admin-secret\" -o ./schema.user.graphqls https://local.graphql.local.nhost.run/v1",
    "codegen": "bun run codegen:graphql-schema && bun run codegen:graphql",
    "test": "bun test",
    "check": "bun run typecheck && bun run lint && bun run test"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@hookform/resolvers": "^3.10.0",
    "@nhost/nhost-js": "^4.7.0",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tanstack/react-query": "^5.95.0",
    "@tanstack/react-query-devtools": "^5.95.0",
    "@tanstack/react-router": "^1.169.1",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/react-start": "^1.167.61",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fuse.js": "^7.3.0",
    "graphql": "^16.13.2",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "recharts": "^3.8.1",
    "sonner": "^1.7.1",
    "tailwind-merge": "^2.6.0",
    "tw-animate-css": "^1.3.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@graphql-codegen/cli": "^5.0.4",
    "@graphql-codegen/client-preset": "^4.5.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bun": "^1.3.13",
    "@types/node": "^22.5.4",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^6.0.1",
    "nitro": "^3.0.260311-beta",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.7.3",
    "vite": "^8.0.0",
    "vite-plugin-pwa": "^1.3.0"
  }
}
