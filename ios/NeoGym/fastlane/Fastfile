# frozen_string_literal: true

require "fileutils"
require "json"
require "shellwords"
require "tempfile"
require_relative "lib/xcode_release"

IOS_ROOT = File.expand_path("..", __dir__)
PRODUCTION_SCHEME = "NeoGym"
PRODUCTION_CONFIGURATION = "Release-Production"
RELEASE_OUTPUT_DIRECTORY = File.join(IOS_ROOT, "fastlane", "output")

opt_out_usage
skip_docs


def selected_environment!(options)
  environment = options[:environment]
  unless %w[development production].include?(environment)
    UI.user_error!("pass environment:development or environment:production")
  end
  environment
end


def production_environment!(options)
  environment = selected_environment!(options)
  UI.user_error!("archive and beta require environment:production") unless environment == "production"
end


def canonical_script!(*arguments)
  command = arguments.map { |argument| Shellwords.escape(argument) }.join(" ")
  sh("cd #{Shellwords.escape(IOS_ROOT)} && #{command}")
end


def generate_variant!(variant)
  canonical_script!("Scripts/generate-project.sh", variant)
end


def release_settings!
  fields = %w[MARKETING_VERSION]
  Tempfile.create(["neogym-release-settings", ".json"]) do |file|
    file.chmod(0o600)
    command = [
      "python3",
      File.join(IOS_ROOT, "Scripts", "read-build-settings.py"),
      "--project", File.join(IOS_ROOT, "NeoGym.xcodeproj"),
      "--scheme", PRODUCTION_SCHEME,
      "--configuration", PRODUCTION_CONFIGURATION,
      "--target", "NeoGym",
      "--output", file.path
    ]
    fields.each { |field| command.concat(["--field", field]) }
    succeeded = system(*command, out: File::NULL, err: File::NULL)
    UI.user_error!("authoritative production build-setting resolution failed") unless succeeded

    begin
      settings = JSON.parse(File.read(file.path))
    rescue JSON::ParserError, SystemCallError
      UI.user_error!("authoritative production build-setting resolution failed")
    end
    unless fields.all? { |field| settings[field].is_a?(String) && !settings[field].empty? }
      UI.user_error!("authoritative production build-setting resolution failed")
    end
    settings
  end
end


def allow_provisioning_updates!
  value = ENV.fetch("ALLOW_PROVISIONING_UPDATES", "0")
  unless %w[0 1].include?(value)
    UI.user_error!("ALLOW_PROVISIONING_UPDATES must be 0 or 1")
  end
  value == "1"
end


def run_xcodebuild!(*arguments)
  canonical_script!("/usr/bin/xcrun", "xcodebuild", *arguments)
end


def with_upload_export_options
  Tempfile.create(["neogym-upload-export-options", ".plist"]) do |file|
    file.chmod(0o600)
    file.write(NeoGym::XcodeRelease.upload_export_options_plist)
    file.flush
    yield file.path
  end
end


def verify_release_artifact!(path)
  canonical_script!("python3", "Scripts/verify-artifact.py", "--variant", "production", path)
end


def create_release_archive!(options)
  production_environment!(options)
  generate_variant!("production")

  settings = release_settings!
  marketing_version = NeoGym::XcodeRelease.marketing_version(
    tracked: settings.fetch("MARKETING_VERSION"),
    override: options[:version] || ENV["MARKETING_VERSION"]
  )

  FileUtils.mkdir_p(RELEASE_OUTPUT_DIRECTORY, mode: 0o700)
  archive_path = File.join(RELEASE_OUTPUT_DIRECTORY, "NeoGym-#{marketing_version}.xcarchive")
  FileUtils.rm_rf(archive_path)

  arguments = NeoGym::XcodeRelease.archive_arguments(
    project: File.join(IOS_ROOT, "NeoGym.xcodeproj"),
    scheme: PRODUCTION_SCHEME,
    configuration: PRODUCTION_CONFIGURATION,
    archive_path: archive_path,
    marketing_version: marketing_version,
    allow_provisioning_updates: allow_provisioning_updates!
  )
  run_xcodebuild!(*arguments)
  UI.user_error!("Xcode did not produce the requested archive path") unless File.directory?(archive_path)

  verify_release_artifact!(archive_path)
  { archive: archive_path, marketing_version: marketing_version }
rescue NeoGym::XcodeRelease::InvalidMarketingVersion => error
  UI.user_error!(error.message)
end


def upload_release!(release)
  archive_path = release.fetch(:archive)
  verify_release_artifact!(archive_path)
  upload_output = File.join(RELEASE_OUTPUT_DIRECTORY, "XcodeUpload")
  FileUtils.rm_rf(upload_output)

  with_upload_export_options do |export_options_path|
    arguments = NeoGym::XcodeRelease.upload_arguments(
      archive_path: archive_path,
      export_path: upload_output,
      export_options_path: export_options_path,
      allow_provisioning_updates: allow_provisioning_updates!
    )
    run_xcodebuild!(*arguments)
  end
end


desc "Materialize the explicitly selected variant and generate the Xcode project"
lane :generate do |options|
  variant = selected_environment!(options)
  generate_variant!(variant)
end


desc "Run Ruby release tests and the canonical credential-free iOS check"
lane :check do |options|
  selected_environment!(options)
  sh("cd #{Shellwords.escape(IOS_ROOT)} && ruby fastlane/test/xcode_release_test.rb")
  canonical_script!("Scripts/check.sh")
end


desc "Create and validate a production archive without uploading"
lane :archive do |options|
  release = create_release_archive!(options)
  UI.success("Validated production archive without uploading")
  release.fetch(:archive)
end


desc "Create, validate, and upload production through the configured Xcode account"
lane :beta do |options|
  release = create_release_archive!(options)
  upload_release!(release)
end
