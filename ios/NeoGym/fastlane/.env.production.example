# Copy to .env.production, then fill every value locally. Never commit it.
# Product configuration (the canonical materializer allowlists only these keys).
DEVELOPMENT_TEAM=
NHOST_SUBDOMAIN=
NHOST_REGION=

# Fastlane-only App Store Connect API key. Keep the .p8 outside the repo or in
# an ignored path. Instead of ASC_KEY_PATH, ASC_KEY_CONTENT may be exported in
# the process environment; set ASC_KEY_CONTENT_BASE64=1 when it is base64 text.
ASC_ISSUER_ID=
ASC_KEY_ID=
ASC_KEY_PATH=

# Xcode signing remains separate from API access. Set to 1 only when the local
# Xcode account is authenticated and allowed to update provisioning profiles.
ALLOW_PROVISIONING_UPDATES=0
