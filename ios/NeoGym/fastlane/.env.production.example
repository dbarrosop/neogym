# Copy to .env.production, then fill every value locally. Never commit it.
# Product configuration (the canonical materializer allowlists only these keys).
DEVELOPMENT_TEAM=
NHOST_SUBDOMAIN=
NHOST_REGION=

# Set to 1 only when the local Xcode account is authenticated and allowed to
# update provisioning profiles. The same Xcode account performs TestFlight upload.
ALLOW_PROVISIONING_UPDATES=0
